class CustomCNNWithDropout(nn.Module):
    def __init__(self, num_classes=2, input_channels=3, dropout_rate=0.01):
        super(CustomCNNWithDropout, self).__init__()
        channels = 128
        self.dropout_rate = dropout_rate

        self.conv1 = nn.Conv2d(input_channels, channels, kernel_size=3, padding=1)
        self.bn1 = nn.BatchNorm2d(channels)
        self.skip1 = nn.Conv2d(input_channels, channels, kernel_size=1)

        self.conv2 = nn.Conv2d(channels, channels, kernel_size=3, padding=1)
        self.bn2 = nn.BatchNorm2d(channels)
        self.skip2 = nn.Conv2d(channels, channels, kernel_size=1)

        self.conv3 = nn.Conv2d(channels, channels, kernel_size=3, padding=1)
        self.bn3 = nn.BatchNorm2d(channels)
        self.skip3 = nn.Conv2d(channels, channels, kernel_size=1)

        self.conv4 = nn.Conv2d(channels, channels, kernel_size=3, padding=1)
        self.bn4 = nn.BatchNorm2d(channels)
        self.skip4 = nn.Conv2d(channels, channels, kernel_size=1)

        self.conv5 = nn.Conv2d(channels, channels, kernel_size=3, padding=1)
        self.bn5 = nn.BatchNorm2d(channels)
        self.skip5 = nn.Conv2d(channels, channels, kernel_size=1)

        self.drop1 = nn.Dropout(p=dropout_rate)
        self.drop2 = nn.Dropout(p=dropout_rate)
        self.drop3 = nn.Dropout(p=dropout_rate)
        self.drop4 = nn.Dropout(p=dropout_rate)
        self.drop5 = nn.Dropout(p=dropout_rate)
        self.classifier_dropout = nn.Dropout(p=dropout_rate)

        self.pool = nn.AdaptiveAvgPool2d(1)
        self.fc = nn.Linear(channels, num_classes)

    def forward(self, x):
        identity = self.skip1(x)
        x = self.bn1(F.relu(self.conv1(x))) + identity
        x = F.max_pool2d(x, 2)
        x = self.drop1(x)

        identity = self.skip2(x)
        x = self.bn2(F.relu(self.conv2(x))) + identity
        x = F.max_pool2d(x, 2)
        x = self.drop2(x)

        identity = self.skip3(x)
        x = self.bn3(F.relu(self.conv3(x))) + identity
        x = F.max_pool2d(x, 2)
        x = self.drop3(x)

        identity = self.skip4(x)
        x = self.bn4(F.relu(self.conv4(x))) + identity
        x = F.max_pool2d(x, 2)
        x = self.drop4(x)

        identity = self.skip5(x)
        x = self.bn5(F.relu(self.conv5(x))) + identity
        x = F.max_pool2d(x, 2)
        x = self.drop5(x)

        x = self.pool(x)
        x = torch.flatten(x, 1)
        x = self.classifier_dropout(x)
        x = self.fc(x)
        return x

    def set_dropout_rate(self, rate):
        self.drop1.p = rate
        self.drop2.p = rate
        self.drop3.p = rate
        self.drop4.p = rate
        self.drop5.p = rate
        self.classifier_dropout.p = rate

model = CustomCNNWithDropout(num_classes=2, dropout_rate=0.05)
