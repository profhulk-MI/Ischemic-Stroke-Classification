# Function to calculate metrics
def calculate_metrics(y_true, y_pred):
    cm = confusion_matrix(y_true, y_pred)
    tn, fp, fn, tp = cm.ravel()
    
    accuracy = accuracy_score(y_true, y_pred)
    precision = precision_score(y_true, y_pred)
    sensitivity = recall_score(y_true, y_pred)  # same as recall
    specificity = tn / (tn + fp)
    f1 = f1_score(y_true, y_pred)
    
    return {
        'confusion_matrix': cm,
        'accuracy': accuracy,
        'precision': precision,
        'sensitivity': sensitivity,
        'specificity': specificity,
        'f1_score': f1
    }

def train_and_evaluate(model, train_loader, val_loader, device, epochs):
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(model.parameters(), lr=0.001, weight_decay=0.001)
    
    best_val_acc = 0.0
    final_train_preds = []
    final_train_labels = []
    final_val_preds = []
    final_val_labels = []
    
    for epoch in range(epochs):
        # Training phase
        model.train()
        running_loss = 0.0
        correct = 0
        total = 0
        
        # Only collect predictions for the final epoch
        if epoch == epochs - 1:
            epoch_train_preds = []
            epoch_train_labels = []
        
        for inputs, labels in train_loader:
            inputs, labels = inputs.to(device), labels.to(device)
            
            optimizer.zero_grad()
            outputs = model(inputs)
            loss = criterion(outputs, labels)
            loss.backward()
            optimizer.step()
            
            running_loss += loss.item()
            _, predicted = outputs.max(1)
            total += labels.size(0)
            correct += predicted.eq(labels).sum().item()
            
            # Collect predictions for the final epoch
            if epoch == epochs - 1:
                epoch_train_preds.extend(predicted.cpu().numpy())
                epoch_train_labels.extend(labels.cpu().numpy())
        
        train_loss = running_loss / len(train_loader)
        train_acc = 100. * correct / total
        
        # Display training metrics for each epoch
        print(f'Epoch {epoch+1}/{epochs}, Train Loss: {train_loss:.4f}, Train Acc: {train_acc:.2f}%')
        
        # Save final epoch predictions
        if epoch == epochs - 1:
            final_train_preds = epoch_train_preds
            final_train_labels = epoch_train_labels
        
        # Validation phase
        model.eval()
        val_loss = 0.0
        val_correct = 0
        val_total = 0
        
        # Only collect predictions for the final epoch
        if epoch == epochs - 1:
            epoch_val_preds = []
            epoch_val_labels = []
        
        with torch.no_grad():
            for inputs, labels in val_loader:
                inputs, labels = inputs.to(device), labels.to(device)
                outputs = model(inputs)
                loss = criterion(outputs, labels)
                
                val_loss += loss.item()
                _, predicted = outputs.max(1)
                val_total += labels.size(0)
                val_correct += predicted.eq(labels).sum().item()
                
                # Collect predictions for the final epoch
                if epoch == epochs - 1:
                    epoch_val_preds.extend(predicted.cpu().numpy())
                    epoch_val_labels.extend(labels.cpu().numpy())
        
        val_loss = val_loss / len(val_loader)
        val_acc = 100. * val_correct / val_total
        
        # Save final epoch predictions
        if epoch == epochs - 1:
            final_val_preds = epoch_val_preds
            final_val_labels = epoch_val_labels
        
        if val_acc > best_val_acc:
            best_val_acc = val_acc
    
    # Calculate final metrics
    train_metrics = calculate_metrics(final_train_labels, final_train_preds)
    val_metrics = calculate_metrics(final_val_labels, final_val_preds)
    
    return train_metrics, val_metrics

# Function to evaluate on test set
def evaluate_on_test(model, test_loader, device):
    model.eval()
    test_correct = 0
    test_total = 0
    all_preds = []
    all_labels = []
    
    with torch.no_grad():
        for inputs, labels in test_loader:
            inputs, labels = inputs.to(device), labels.to(device)
            outputs = model(inputs)
            
            _, predicted = outputs.max(1)
            test_total += labels.size(0)
            test_correct += predicted.eq(labels).sum().item()
            
            # Store predictions and labels for metrics calculation
            all_preds.extend(predicted.cpu().numpy())
            all_labels.extend(labels.cpu().numpy())
    
    test_metrics = calculate_metrics(all_labels, all_preds)
    
    return test_metrics


